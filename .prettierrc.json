{
  "printWidth": 105,
  "singleQuote": false,
  "semi": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react",
    "^next(/.*)?$",
    "<THIRD_PARTY_MODULES>",
    "^@/lib/(.*)$",
    "^@/hooks/(.*)$",
    "^@/providers/(.*)$",
    "^@/types(.*)$",
    "^@/components/(.*)$",
    "^[.]"
  ],
  "importOrderTypeScriptVersion": "5.0.0"
}
